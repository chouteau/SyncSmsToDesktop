<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="SmsSyncWindows.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SmsSyncWindows"
    xmlns:models="using:SmsSyncWindows.Models"
    xmlns:helpers="using:SmsSyncWindows.Helpers"
    xmlns:converters="using:SmsSyncWindows.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:BooleanToVisibilityConverter x:Key="InverseBoolToVis" IsReversed="True" />

        <!-- Template pour les SMS reçus (Incoming) -->
        <DataTemplate x:Key="IncomingMessageTemplate" x:DataType="models:SmsMessage">
            <Grid Margin="12,4,48,4" HorizontalAlignment="Left">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <Border CornerRadius="12,12,12,0" 
                        Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" 
                        Padding="12,8" 
                        BorderBrush="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                        BorderThickness="1">
                    <TextBlock Text="{x:Bind Body}" 
                               TextWrapping="Wrap" 
                               Foreground="{ThemeResource SystemControlPageTextBaseHighBrush}"
                               FontSize="14"/>
                </Border>
                
                <TextBlock Grid.Row="1" 
                           Text="{x:Bind FormattedTime}" 
                           FontSize="10" 
                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                           Margin="4,2,0,0" 
                           HorizontalAlignment="Left"/>
            </Grid>
        </DataTemplate>

        <!-- Template pour les SMS envoyés (Outgoing) -->
        <DataTemplate x:Key="OutgoingMessageTemplate" x:DataType="models:SmsMessage">
            <Grid Margin="48,4,12,4" HorizontalAlignment="Right">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <Border CornerRadius="12,12,0,12" 
                        Background="{ThemeResource SystemAccentColor}" 
                        Padding="12,8">
                    <TextBlock Text="{x:Bind Body}" 
                               TextWrapping="Wrap" 
                               Foreground="White"
                               FontSize="14"/>
                </Border>
                
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2,4,0">
                    <TextBlock Text="{x:Bind FormattedTime}" 
                               FontSize="10" 
                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                               Margin="0,0,4,0"/>
                    <FontIcon Glyph="&#xE73E;" 
                              FontSize="10" 
                              Foreground="{ThemeResource SystemAccentColor}" 
                              Visibility="{x:Bind IsSynced, Converter={StaticResource BoolToVis}}" />
                    <FontIcon Glyph="&#xE10C;" 
                              FontSize="10" 
                              Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                              Visibility="{x:Bind IsSynced, Converter={StaticResource InverseBoolToVis}}" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <helpers:MessageTemplateSelector x:Key="SmsTemplateSelector"
            IncomingTemplate="{StaticResource IncomingMessageTemplate}"
            OutgoingTemplate="{StaticResource OutgoingMessageTemplate}" />
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>        <!-- COLONNE GAUCHE : Conversations & Statut -->
        <Grid Grid.Column="0" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Statut -->
                <RowDefinition Height="Auto" /> <!-- Nouveau Message -->
                <RowDefinition Height="*" />    <!-- Conversations -->
                <RowDefinition Height="Auto" /> <!-- Bouton -->
            </Grid.RowDefinitions>

            <!-- En-tête statut de connexion -->
            <StackPanel Grid.Row="0" Padding="16,12" Spacing="8" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                <TextBlock Text="SMS Sync Client" FontSize="18" FontWeight="SemiBold" />
                
                <!-- Témoin de connexion -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <Ellipse Width="10" Height="10" 
                              Fill="LimeGreen" 
                              Visibility="{x:Bind ViewModel.IsConnected, Mode=OneWay, Converter={StaticResource BoolToVis}}" 
                              Tag="Connected" />
                    <Ellipse Width="10" Height="10" 
                              Fill="Gray" 
                              Visibility="{x:Bind ViewModel.IsConnected, Mode=OneWay, Converter={StaticResource InverseBoolToVis}}" />
                    <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" 
                               FontSize="12" 
                               TextWrapping="Wrap" 
                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Adresse IP de connexion -->
                <Border CornerRadius="4" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" Padding="8,4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="IP PC :" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ViewModel.ServerIpPort, Mode=OneWay}" FontSize="11" IsTextSelectionEnabled="True" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Barre de progression de synchronisation -->
                <StackPanel Spacing="4" Margin="0,4,0,0" Visibility="{x:Bind ViewModel.IsSyncing, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <ProgressBar Minimum="0" Maximum="100" Value="{x:Bind ViewModel.SyncProgressValue, Mode=OneWay}" Height="4" IsIndeterminate="False"/>
                    <TextBlock Text="{x:Bind ViewModel.SyncStatusText, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                </StackPanel>
            </StackPanel>

            <!-- Démarrer une nouvelle conversation -->
            <Grid Grid.Row="1" Padding="16,12,16,8" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{ThemeResource SystemControlBackgroundChromeMediumBrush}" BorderThickness="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="NewConversationNumberBox" 
                         PlaceholderText="Nouveau numéro..." 
                         KeyDown="OnNewConversationNumberBoxKeyDown"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"/>
                <Button Grid.Column="1" 
                        Content="Démarrer" 
                        Click="OnStartNewConversationClicked"
                        Style="{StaticResource AccentButtonStyle}"
                        VerticalAlignment="Center"/>
            </Grid>

            <!-- Liste des discussions -->
            <ListView Grid.Row="2" 
                      ItemsSource="{x:Bind ViewModel.Conversations, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedConversation, Mode=TwoWay}"
                      SelectionMode="Single"
                      Padding="0,8">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Conversation">
                        <Grid Margin="0,4" Padding="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <!-- Avatar rond initiales (Normal) -->
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" 
                                    Background="{ThemeResource SystemAccentColor}" 
                                    Margin="0,0,12,0" 
                                    VerticalAlignment="Center"
                                    Visibility="{x:Bind IsFavorite, Mode=OneWay, Converter={StaticResource InverseBoolToVis}}">
                                <TextBlock Text="✉" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" 
                                           Foreground="White" 
                                           FontWeight="Bold"/>
                            </Border>

                            <!-- Avatar rond initiales (Favori) -->
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" 
                                    Background="#FFFFB300" 
                                    Margin="0,0,12,0" 
                                    VerticalAlignment="Center"
                                    Visibility="{x:Bind IsFavorite, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="★" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" 
                                           Foreground="White" 
                                           FontSize="18"
                                           FontWeight="Bold"/>
                            </Border>


                            <!-- Détails de la conversation -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}" 
                                           FontWeight="SemiBold" 
                                           TextTrimming="CharacterEllipsis" 
                                           FontSize="14"/>
                                <TextBlock Text="{x:Bind LatestMessage, Mode=OneWay}" 
                                           FontSize="12" 
                                           Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                                           TextTrimming="CharacterEllipsis" 
                                           MaxLines="1" 
                                           Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Date/Heure -->
                            <TextBlock Grid.Column="2" 
                                       Text="{x:Bind FormattedLatestMessageTime, Mode=OneWay}" 
                                       FontSize="10" 
                                       Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                                       VerticalAlignment="Top" 
                                       Margin="8,4,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            
            <Button Grid.Row="3" Content="Actualiser" Margin="16" HorizontalAlignment="Stretch" Click="OnRefreshClicked"/>
        </Grid>

        <!-- SÉPARATEUR VERTICAL -->
        <Border Grid.Column="1" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" />

        <!-- COLONNE DROITE : Messages -->
        <Grid Grid.Column="2">
            <!-- État vide (Aucune conversation sélectionnée) -->
            <Grid Visibility="{x:Bind ViewModel.HasSelectedConversation, Mode=OneWay, Converter={StaticResource InverseBoolToVis}}"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE11F;" FontSize="64" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                    <TextBlock Text="Sélectionnez une conversation pour commencer" 
                               FontSize="16" 
                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Connectez l'application mobile à l'adresse ci-contre" 
                               FontSize="12" 
                               Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Vue de la conversation active -->
            <Grid Visibility="{x:Bind ViewModel.HasSelectedConversation, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- En-tête de la discussion -->
                <Grid Padding="24,16" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind ViewModel.SelectedConversation.DisplayName, Mode=OneWay}" 
                                   FontSize="20" 
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind ViewModel.SelectedConversation.Address, Mode=OneWay}" 
                                   FontSize="12" 
                                   Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                    </StackPanel>
                </Grid>

                <!-- Liste des bulles de messages -->
                <ListView x:Name="MessagesList"
                          Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.SelectedConversation.Messages, Mode=OneWay}"
                          ItemTemplateSelector="{StaticResource SmsTemplateSelector}"
                          SelectionMode="None"
                          Padding="12,12,12,24">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel ItemsUpdatingScrollMode="KeepLastItemInView" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                </ListView>

                <!-- Zone de saisie d'envoi -->
                <Grid Grid.Row="2" Padding="24,16" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{ThemeResource SystemControlBackgroundChromeMediumBrush}" BorderThickness="0,1,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" 
                             PlaceholderText="Tapez votre message..." 
                             Text="{x:Bind ViewModel.NewMessageText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="OnNewMessageTextBoxKeyDown"
                             AcceptsReturn="True" 
                             MaxHeight="80" 
                             VerticalAlignment="Center" 
                             Margin="0,0,12,0" />

                    <Button Grid.Column="1" 
                            Style="{StaticResource AccentButtonStyle}" 
                            Width="44" 
                            Height="36" 
                            Click="OnSendClicked" 
                            VerticalAlignment="Bottom">
                        <FontIcon Glyph="&#xE122;" FontSize="16" />
                    </Button>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
